# Copier en .env et adapter aux identifiants de schoolmatrix-db-dev.
# Si l'API affiche "password authentication failed", vérifiez avec :
#   docker exec schoolmatrix-db-dev env
# puis mettez ici les mêmes POSTGRES_USER / POSTGRES_PASSWORD (s'ils sont définis).

DB_PORT=5433
DB_USER=schoolmatrix
DB_PASS=schoolmatrix
DB_NAME=schoolmatrix
JWT_SECRET=change_me
