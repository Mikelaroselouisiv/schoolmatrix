# Production locale SchoolMatrix — copier en .env et adapter
# Utilisé par : docker-compose.prod-local.yml, docker-compose.prod-local-ecr.yml,
#               scripts/start-prod-local-build.js, scripts/update-prod-local-ecr.js

# Dossier racine des données (obligatoire)
SCHOOLMATRIX_DATA=C:/SchoolMatrix

# PostgreSQL
DB_USER=schoolmatrix
DB_PASS=schoolmatrix
DB_NAME=schoolmatrix

# ECR (pour update-prod-local-ecr.js)
ECR_REGISTRY=421983920969.dkr.ecr.us-east-2.amazonaws.com
AWS_REGION=us-east-2
IMAGE_TAG=latest

# AWS S3 — remplir manuellement pour le stockage cloud
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=drive-mike
AWS_S3_PREFIX=schoolmatrix
