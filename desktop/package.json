{
  "name": "parallele-schoolmatrix-desktop",
  "version": "1.0.8",
  "description": "Application desktop Electron pour Parallele SchoolMatrix",
  "main": "main.js",
  "author": "Parallele SchoolMatrix",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.parallele.schoolmatrix",
    "productName": "Parallele SchoolMatrix",
    "directories": {
      "output": "dist"
    },
    "files": ["main.js", "installer.html", "App logo.png", "package.json"],
    "extraResources": [
      { "from": "../scripts", "to": "scripts", "filter": ["**/*"] },
      { "from": "../docker-compose.prod-local.yml", "to": "." },
      { "from": "../docker-compose.prod-local-ecr.yml", "to": "." }
    ],
    "win": {
      "target": "nsis",
      "icon": "App logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  }
}
