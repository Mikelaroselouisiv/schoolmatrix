# Base de données (même base que Docker : docker compose up -d pour lancer uniquement la base)
DB_HOST=localhost
DB_PORT=5432
DB_USER=schoolmatrix
DB_PASS=schoolmatrix
DB_NAME=schoolmatrix

# JWT (requis)
JWT_SECRET=your-secret-key-change-in-production

# Stockage local (défaut: ./storage)
# STORAGE_ROOT=./storage

# Nœud de synchronisation (LOCAL ou CLOUD)
# NODE_ID=LOCAL

# S3 (optionnel - laisser vide pour désactiver le backup S3)
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=drive-mike
# AWS_S3_PREFIX=schoolmatrix
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# NODE_ENV=development utilise .env.dev
