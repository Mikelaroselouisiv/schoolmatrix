# Base de données (requis)
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=

# JWT (requis)
JWT_SECRET=

# Stockage local (chemin absolu recommandé en production)
# STORAGE_ROOT=/app/storage

# Nœud de synchronisation (LOCAL ou CLOUD)
# NODE_ID=LOCAL

# S3 (pour backup des fichiers)
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=drive-mike
# AWS_S3_PREFIX=schoolmatrix
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# NODE_ENV=production utilise .env.prod
# Copier vers .env.prod et remplir les valeurs.
#
# En production locale Docker (docker-compose.prod-local.yml) :
# Placer ce fichier dans le dossier racine des données (ex. C:\SchoolMatrix\.env.prod)
# et définir DB_HOST=db, DB_PORT=5432 (les autres DB_* comme dans le .env du projet).
