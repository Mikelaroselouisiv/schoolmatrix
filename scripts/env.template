# Template pour .env (compose) / .env.prod (API) — remplacer les valeurs en production.
# Ne pas commiter de secrets. Utilisé par prepare-prod-local.js et install-schoolmatrix-ec2.sh.

# Dossier racine des données (production locale uniquement)
SCHOOLMATRIX_DATA=

# Base de données
DB_HOST=db
DB_PORT=5432
DB_USER=schoolmatrix
DB_PASS=schoolmatrix
DB_NAME=schoolmatrix

# JWT (obligatoire en production)
JWT_SECRET=

# AWS S3 / ECR — à remplir manuellement
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_PREFIX=

# ECR (pour docker-compose avec images ECR)
ECR_REGISTRY=
AWS_REGION=us-east-2
IMAGE_TAG=latest
